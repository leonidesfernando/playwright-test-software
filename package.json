{
  "name": "playwright-test-software",
  "version": "1.0.0",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^7.5.0",
    "@playwright/test": "^1.55",
    "@types/mocha": "^9.1.1",
    "@typescript-eslint/eslint-plugin": "^5.37.0",
    "allure-commandline": "^2.32.0",
    "allure-playwright": "^3.0.6",
    "eslint": "^8.23.1",
    "eslint-config-standard-with-typescript": "^23.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.2.5",
    "eslint-plugin-promise": "^6.0.1",
    "mocha": "^10.0.0",
    "rimraf": "^3.0.2",
    "typescript": "^4.8.3"
  },
  "scripts": {
    "lint": "npx standard",
    "lint:fix": "npx standard --fix",
    "test": "npx playwright test",
    "api": "npx playwright test --project=api",
    "e2e": "npx playwright test --project=e2e",
    "report": "npx playwright show-report",
    "clean": "rimraf dist/*, test-results/*, allure-results/*, playwright-report/*",
    "build": "npm run clean && tsc",
    "allure:generate": "npx allure generate ./allure-results --clean",
    "allure:open": "npx allure open ./allure-report",
    "allure": "npm run allure:generate && npm run allure:open",
    "allure:serve": "npx allure serve"
  }
}
